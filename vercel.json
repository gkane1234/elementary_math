{
  "services": {
    "web": {
      "framework": "nextjs",
      "root": "."
    },
    "pyapi": {
      "framework": "fastapi",
      "root": ".",
      "entrypoint": "backend.main:app"
    }
  },
  "rewrites": [
    {
      "source": "/api/generate",
      "destination": { "service": "pyapi" }
    },
    {
      "source": "/api/question-types",
      "destination": { "service": "pyapi" }
    },
    {
      "source": "/(.*)",
      "destination": { "service": "web" }
    }
  ]
}
